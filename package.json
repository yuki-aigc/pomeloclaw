{
    "name": "srebot",
    "version": "1.0.0",
    "description": "srebot: 智能助手，支持记忆、技能、定时任务与多渠道接入",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.ts",
        "dingtalk": "tsx src/dingtalk.ts",
        "ios": "tsx src/ios.ts",
        "web": "tsx src/web.ts",
        "hooks": "tsx src/hooks.ts",
        "server": "tsx src/server.ts",
        "channels": "tsx src/server.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "start:server": "node dist/server.js",
        "start:channels": "node dist/server.js",
        "start:ios": "node dist/ios.js",
        "start:web": "node dist/web.js",
        "start:hooks": "node dist/hooks.js",
        "typecheck": "tsc --noEmit",
        "test": "tsx --test \"src/**/*.test.ts\"",
        "test:watch": "tsx --test --watch \"src/**/*.test.ts\""
    },
    "keywords": [
        "deepagents",
        "ai",
        "agent",
        "sre"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@langchain/anthropic": "^1.3.22",
        "@langchain/core": "^1.1.31",
        "@langchain/langgraph": "^1.2.1",
        "@langchain/mcp-adapters": "^1.1.3",
        "@langchain/openai": "^1.2.12",
        "adm-zip": "^0.5.16",
        "axios": "^1.7.0",
        "croner": "^10.0.1",
        "deepagents": "^1.8.1",
        "dingtalk-stream": "^2.1.4",
        "langchain": "^1.2.30",
        "pg": "^8.18.0",
        "ws": "^8.19.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/adm-zip": "^0.5.7",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.16.0",
        "@types/ws": "^8.18.1",
        "tsx": "^4.19.0",
        "typescript": "^5.5.0"
    }
}
